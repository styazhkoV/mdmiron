            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c5.51 0 10-4.48 10-10S17.51 2 12 2zm6.605 4.61a8.502 8.502 0 011.93 5.314c-.281-.054-3.101-.629-5.943-.271-.065-.156-.12-.302-.177-.449a15.42 15.42 0 00-1.61-3.084 19.336 19.336 0 005.797-1.51zm-1.443-1.444A17.152 17.152 0 0111.66 9.49 13.9 13.9 0 009.68 5.385a8.498 8.498 0 017.482-.217zM9.54 3.73a15.82 15.82 0 012.13 4.29 19.458 19.458 0 00-4.08 1.968C6.01 7.23 7.85 4.6 9.54 3.73zm-.51 16.48A8.496 8.496 0 012.63 12.5c2.4-.41 5.92-.12 8.78 1.54A15.495 15.495 0 009.03 20.21zM11 21.65a13.33 13.33 0 011.08-5.83c1.7 1.04 3.65 1.51 5.48 1.63a8.5 8.5 0 01-6.56 4.2z" clip-rule="evenodd" />
