        </div>
      </div>
      
      <div>
        <h3 class="text-white font-mono font-bold uppercase tracking-widest mb-4 border-b border-light/10 pb-2">Links</h3>
        <ul class="space-y-3 font-mono text-sm text-gray-400">
          <li><a href="/#about" class="hover:text-accent transition-colors">About</a></li>
          <li><a href="/#events" class="hover:text-accent transition-colors">Events</a></li>
          <li><a href="/#music" class="hover:text-accent transition-colors">Music</a></li>
          <li><a href="/#contact" class="hover:text-accent transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-white font-mono font-bold uppercase tracking-widest mb-4 border-b border-light/10 pb-2">Contact</h3>
        <ul class="space-y-3 font-mono text-sm text-gray-400">
          <li>For bookings & inquiries:</li>
          <li><a href="mailto:booking@mdmron.com" class="text-white hover:text-accent transition-colors">booking@mdmron.com</a></li>
          <li class="mt-4">Based in:</li>
          <li class="text-white">Underground</li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 font-mono text-xs">
        &copy; {currentYear} MD MRON. All rights reserved.
      </p>
      <p class="text-gray-500 font-mono text-xs flex gap-4">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </p>
    </div>
  </div>
</footer>
