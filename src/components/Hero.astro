---
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Video Background (Placeholder) -->
  <div class="absolute inset-0 w-full h-full z-0 bg-dark">
    <!-- Replace src with actual video -->
    <video 
      autoplay 
      loop 
      muted 
      playsinline 
      class="object-cover w-full h-full opacity-30 mix-blend-luminosity grayscale"
    >
      <source src="https://assets.codepen.io/3364143/7btrrd.mp4" type="video/mp4" />
    </video>
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-dark/80 via-dark/40 to-dark"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 text-center flex flex-col items-center">
    <p class="font-mono text-accent uppercase tracking-[0.3em] text-sm md:text-md mb-6 animate-pulse">
      Dark / Minimal / Industrial
    </p>
    
    <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-white font-sans tracking-tighter mix-blend-difference mb-8">
      MD<span class="text-accent opacity-90">MRON</span>
    </h1>
    
    <p class="max-w-xl mx-auto text-gray-400 font-mono text-sm md:text-base leading-relaxed mb-12">
      Curating immersive techno experiences. A journey through deep, dark, and relentless soundscapes.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="#events" class="btn-accent">
        Upcoming Events
      </a>
      <a href="#music" class="btn-outline">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
        </svg>
        Listen Now
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10 opacity-70">
    <span class="font-mono text-[10px] uppercase tracking-widest text-white">Scroll</span>
    <div class="w-[1px] h-10 bg-white/30 relative overflow-hidden">
      <div class="w-full h-1/2 bg-white absolute top-0 animate-[shimmer_2s_infinite]"></div>
    </div>
  </div>
</section>

<style>
  @keyframes shimmer {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
</style>
